[webservers]
web1 ansible_host=localhost ansible_connection=local
web2 ansible_host=localhost ansible_connection=local
# web3 ansible_host=192.168.1.10 ansible_user=ubuntu

[dbservers]
db1 ansible_host=localhost ansible_connection=local
# db2 ansible_host=192.168.1.11 ansible_user=ubuntu

[appservers]
app1 ansible_host=localhost ansible_connection=local

[production:children]
